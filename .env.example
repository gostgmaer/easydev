# Environment Variables for Production
# Copy this file to .env.local and fill in your actual values

# ─── Backend API ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_BASE_URL=https://web-agency-backend-api.vercel.app/api

# ─── Site ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://www.easydev.in

# ─── Maintenance mode ─────────────────────────────────────────────────────────
# Set to "true" to show the coming-soon page instead of the full site
IS_MAINTENANCE=false

# ─── Analytics ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_GA_ID=

# ─── Supabase (optional — only if database features are enabled) ──────────────
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ─── Email (choose one provider) ─────────────────────────────────────────────
RESEND_API_KEY=
SENDGRID_API_KEY=
MAILGUN_API_KEY=
MAILGUN_DOMAIN=

# ─── Newsletter (choose one provider) ────────────────────────────────────────
MAILCHIMP_API_KEY=
MAILCHIMP_SERVER_PREFIX=
MAILCHIMP_AUDIENCE_ID=